generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// SESSION (Shopify OAuth)
// ============================================
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ============================================
// SHOPIFY METADATA CACHE
// ============================================
// Caches slow Shopify metadata queries (vendors, publications, metafield
// definitions, locations, option values). See shopify-cache.server.ts.
model ShopifyCache {
  id        String   @id @default(cuid())
  shop      String
  key       String
  value     String // JSON-encoded
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}

// ============================================
// INVENTORY PLANNER
// ============================================
model InventoryConfig {
  id                String   @id @default(cuid())
  shop              String
  shopifyProductId  String
  shopifyVariantId  String?
  shopifyLocationId String? // per-location min levels
  minInventoryLevel Int      @default(0)
  coverageDays      Int      @default(90)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, shopifyProductId, shopifyVariantId, shopifyLocationId])
  @@index([shop])
}

model SalesSnapshot {
  id               String   @id @default(cuid())
  shop             String
  shopifyProductId String
  shopifyVariantId String
  periodStart      DateTime
  periodType       String // "weekly" | "monthly"
  quantitySold     Int
  revenue          Float
  createdAt        DateTime @default(now())

  @@unique([shop, shopifyVariantId, periodStart, periodType])
  @@index([shop, shopifyProductId])
  @@index([periodStart])
}

model SyncStatus {
  id            String    @id @default(cuid())
  shop          String    @unique
  lastSyncAt    DateTime
  lastOrderDate DateTime?
  status        String    @default("idle") // "idle" | "syncing" | "error"
  error         String?
  updatedAt     DateTime  @updatedAt
}

// Denormalized per-variant snapshot used by the Planning table. Rebuilt
// on-demand or on a nightly cron.
model PlanningSnapshot {
  id                 String   @id @default(cuid())
  shop               String
  shopifyProductId   String
  shopifyVariantId   String
  periodDays         Int // e.g. 365
  unitsSold          Int      @default(0)
  unitsSoldPriorYear Int      @default(0)
  daysOOS            Int      @default(0) // days out of stock in period
  generatedAt        DateTime @default(now())

  @@unique([shop, shopifyVariantId, periodDays])
  @@index([shop, generatedAt])
}

// ============================================
// PURCHASE ORDERS
// ============================================
model PurchaseOrder {
  id                String    @id @default(cuid())
  shop              String
  poNumber          String
  poNumberExt       String? // vendor's own PO #
  designId          String? // internal design / style reference, printed on the PDF when set
  name              String? // human-friendly label, primary display in lists
  vendor            String?
  status            String    @default("draft") // draft | ordered | partially_received | received | cancelled
  notes             String?
  orderDate         DateTime?
  shippingDate      DateTime?
  expectedDate      DateTime?
  totalCost         Float     @default(0)
  shopifyLocationId String? // where received inventory lands
  receiveToken      String    @default(cuid()) // used for scan-to-receive signed URL
  pdfGeneratedAt    DateTime?
  paidAt            DateTime? // null = unpaid; timestamp = when user marked it paid
  printedAt         DateTime? // null = unprinted; timestamp = when user marked it printed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lineItems PurchaseOrderLineItem[]

  @@unique([shop, poNumber])
  @@index([shop, status])
  @@index([receiveToken])
}

model PurchaseOrderLineItem {
  id               String   @id @default(cuid())
  purchaseOrderId  String
  shopifyProductId String
  shopifyVariantId String
  productTitle     String
  variantTitle     String
  sku              String?
  barcode          String?
  designId         String? // per-row (product+color) internal design ref; printed on PDF when set
  unitCost         Float    @default(0)
  retailPrice      Float    @default(0)
  quantityOrdered  Int      @default(0)
  quantityReceived Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([shopifyVariantId])
}

// ============================================
// INVENTORY TRANSFERS (location-to-location)
// ============================================
model InventoryTransfer {
  id             String    @id @default(cuid())
  shop           String
  transferNumber String
  name           String? // human-friendly label, primary display in lists
  fromLocationId String
  toLocationId   String
  status         String    @default("draft") // draft | in_transit | received | cancelled
  notes          String?
  receiveToken   String    @default(cuid()) // public scan-to-receive token (mirrors PO.receiveToken)
  trackingCarrier String?  // free-text carrier name (UPS, FedEx, USPS, …)
  trackingNumber  String?  // manually entered; links out to carrier tracking
  createdAt      DateTime  @default(now())
  sentAt         DateTime?
  receivedAt     DateTime?
  updatedAt      DateTime  @updatedAt

  lineItems InventoryTransferLineItem[]

  @@unique([shop, transferNumber])
  @@index([shop, status])
  @@index([receiveToken])
}

model InventoryTransferLineItem {
  id               String   @id @default(cuid())
  transferId       String
  shopifyProductId String
  shopifyVariantId String
  productTitle     String
  variantTitle     String
  sku              String?
  quantitySent     Int      @default(0)
  quantityReceived Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transfer InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

// ============================================
// INVENTORY ADJUSTMENTS (audit log)
// ============================================
// A "session" is one grid-based batch adjust (inventory correction, cycle count
// reconciliation, damaged writedown, etc.). Changes rows record per-variant deltas.
model InventoryAdjustmentSession {
  id         String   @id @default(cuid())
  shop       String
  locationId String
  reason     String // Shopify reason enum: correction | cycle_count_available | damaged | received | shrinkage | restock | other (per Admin API 2025-01+)
  source     String   @default("manual") // manual | po_receive | transfer_receive | stock_count
  sourceId   String? // e.g. PO id, Transfer id, StockCount id
  notes      String?
  createdAt  DateTime @default(now())
  createdBy  String? // optional user identifier (staff id / email)

  changes InventoryAdjustmentChange[]

  @@index([shop, createdAt])
  @@index([source, sourceId])
}

model InventoryAdjustmentChange {
  id                     String @id @default(cuid())
  sessionId              String
  shopifyVariantId       String
  shopifyInventoryItemId String
  previousQuantity       Int
  newQuantity            Int
  delta                  Int

  session InventoryAdjustmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([shopifyVariantId])
}

// ============================================
// STOCK COUNTS (cycle counts)
// ============================================
model StockCount {
  id          String    @id @default(cuid())
  shop        String
  locationId  String
  name        String
  status      String    @default("in_progress") // in_progress | completed | abandoned
  notes       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  lineItems StockCountLineItem[]

  @@index([shop, status])
}

model StockCountLineItem {
  id               String    @id @default(cuid())
  stockCountId     String
  shopifyProductId String
  shopifyVariantId String
  productTitle     String
  vendor           String? // snapshot at count creation — drives grouping
  variantTitle     String
  sku              String?
  barcode          String?
  variantOptions   String? // JSON [{name,value}] — drives sizes-as-columns grid
  expectedQuantity Int // snapshot at count creation
  countedQuantity  Int? // null until counted
  countedAt        DateTime?
  countedBy        String?
  // Autosaved as-you-type buffer. `null` = no draft in flight. Cleared
  // atomically when a row is Save-Row'd (drops to countedQuantity).
  draftQuantity    Int?
  // Client-supplied timestamp of the last user edit. Used server-side
  // as a stale-write guard when a debounced draft POST arrives after
  // Save Row or a scan has already committed the line.
  draftUpdatedAt   DateTime?

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)

  @@unique([stockCountId, shopifyVariantId])
  @@index([stockCountId])
  // Powers the "when was this variant last counted, at this location?"
  // lookup that surfaces prior-count subtext on the counting screen.
  @@index([shopifyVariantId, countedAt])
}

// ============================================
// PRODUCT BULK ACTIONS (audit log — V2.1 Products module)
// ============================================
// A "session" is one bulk edit run from the Products module (change vendor,
// set COGs, add/remove tags, archive). Changes rows record per-product
// before/after values so catastrophic edits can be reviewed and reversed.
model ProductBulkActionSession {
  id         String   @id @default(cuid())
  shop       String
  action     String // change_vendor | set_cogs | edit_tags | archive
  notes      String? // optional context (e.g. filter used)
  createdAt  DateTime @default(now())
  createdBy  String? // optional staff identifier
  totalCount Int      @default(0) // # products targeted
  okCount    Int      @default(0) // # that succeeded
  errorCount Int      @default(0)

  changes ProductBulkActionChange[]

  @@index([shop, createdAt])
  @@index([action])
}

model ProductBulkActionChange {
  id               String   @id @default(cuid())
  sessionId        String
  shopifyProductId String
  productTitle     String?
  field            String // vendor | status | tags | cost
  previousValue    String? // JSON or scalar string
  newValue         String? // JSON or scalar string
  ok               Boolean  @default(true)
  error            String?
  createdAt        DateTime @default(now())

  session ProductBulkActionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([shopifyProductId])
}

// ============================================
// REPORTS (V2.1 — Reports module)
// ============================================
// Nightly snapshot of inventory value at each (shop, location, optional
// vendor) slice. Required for turnover math (COGS / avg inventory across
// the period) and for historical stock-on-hand trends.
// DEPRECATED — kept read-only for the pre-cutover Stocky historical
// trend (382 days of shop-total cost + retail imported from Stocky's
// historical_stock_on_hand CSVs). Ongoing snapshots now go into
// VariantDaySnapshot below, which supports per-variant / per-product
// / per-category valuation instead of just shop-total rollups.
model InventoryValueSnapshot {
  id               String   @id @default(cuid())
  shop             String
  locationId       String
  vendor           String? // null = all-vendor rollup for that location
  periodEnd        DateTime // end-of-day timestamp the snapshot represents
  totalUnits       Int      @default(0)
  totalCostValue   Float    @default(0)
  totalRetailValue Float    @default(0)
  generatedAt      DateTime @default(now())

  @@unique([shop, locationId, vendor, periodEnd])
  @@index([shop, periodEnd])
  @@index([shop, locationId, periodEnd])
}

// ============================================
// DEMAND FORECASTING + INVENTORY VALUATION
// ============================================
// Nightly per-variant snapshot. Captures on_hand, day's units_sold,
// AND unit_cost + price AS-OF-THE-DAY (cost and price drift; capturing
// them at snapshot time is what makes historical valuation possible).
// One row per variant per day. Idempotent on (shop, date, variantId).
// on_hand can be negative — Shopify allows overselling; we preserve it
// so downstream can subtract it as "owed" units in reorder math.
model VariantDaySnapshot {
  id                String   @id @default(cuid())
  shop              String
  date              DateTime // end-of-day UTC of the represented day
  shopifyVariantId  String
  shopifyProductId  String
  productTitle      String   @default("")
  productType       String   @default("") // Shopify product_type, drives seasonality category
  onHand            Int      @default(0) // sum across locations (can be negative)
  unitsSold         Int      @default(0) // net line items = sales − refunds
  unitCost          Float    @default(0)
  price             Float    @default(0)
  createdAt         DateTime @default(now())

  @@unique([shop, date, shopifyVariantId])
  @@index([shop, date])
  @@index([shop, shopifyVariantId])
  @@index([shop, shopifyProductId])
}

// Monthly rollup for pre-cutover history. Populated by the one-shot
// backfill (Shopify GraphQL orders + ShopifyQL inventory analytics).
// Once daily VariantDaySnapshot rows accumulate for a month, downstream
// prefers those and this table is just the cold-start scaffold.
model VariantMonthSnapshot {
  id                 String   @id @default(cuid())
  shop               String
  month              String // "YYYY-MM"
  shopifyVariantId   String
  shopifyProductId   String
  productTitle       String   @default("")
  productType        String   @default("")
  unitsSold          Int      @default(0)
  // Approximate share of days that month with on_hand > 0.
  // Coded values from the backfill heuristic:
  //   1.0  = stock at both month start and end
  //   0.5  = stock at only one endpoint
  //   0.25 = sold that month despite both endpoints being zero
  //   0.0  = no stock, no sales
  inStockFraction    Float    @default(1.0)
  source             String   @default("approx") // "approx" | "backfilled_daily"
  createdAt          DateTime @default(now())

  @@unique([shop, month, shopifyVariantId])
  @@index([shop, month])
  @@index([shop, shopifyVariantId])
  @@index([shop, shopifyProductId])
}

// Per-category monthly seasonality multipliers (12 values, mean ≈ 1.0).
// "category" is a free-form key — the forecast engine looks up a
// product's category as ProductForecastConfig.category ?? product.productType.
// Recompute yearly from availability-corrected demand.
model SeasonalIndex {
  id        String   @id @default(cuid())
  shop      String
  category  String
  month     Int // 1..12
  value     Float    @default(1.0)
  updatedAt DateTime @updatedAt

  @@unique([shop, category, month])
  @@index([shop, category])
}

// Per-product overrides on the global forecast defaults. Everything is
// optional — unset fields fall back to the engine defaults.
model ProductForecastConfig {
  id               String   @id @default(cuid())
  shop             String
  shopifyProductId String
  category         String? // overrides productType for seasonality lookup
  safetyBuffer     Float? // e.g. 0.25 = +25% cushion on top of forecast
  growth           Float? // e.g. 0.20 = +20% YoY growth expectation
  leadTimeDays     Int? // supplier lead time
  moq              Int? // supplier minimum order quantity
  casePack         Int? // round suggested_order up to nearest N
  updatedAt        DateTime @updatedAt

  @@unique([shop, shopifyProductId])
  @@index([shop])
}

// ============================================
// PRODUCT BUILDER (templates, optional)
// ============================================
model ProductTemplate {
  id            String   @id @default(cuid())
  shop          String
  name          String
  category      String // "mens" | "womens" | "other"
  defaultVendor String?
  skuPattern    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
}
